<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="STprogram2LH.MainPage"
             BackgroundColor="{StaticResource PrimaryBackground}"
             Title="MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label
                Text="Georgia Tours"
                TextColor="Black"
                FontAttributes="Bold"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Image
                Source="georgias.jpg"
                HeightRequest="250"
                WidthRequest="400"
                Aspect="AspectFill"
                SemanticProperties.Description="dot net bot in a race car number eight" />

            
            <Label
                Text="Discover the hottest spots in Georgia!"
                TextColor="Black"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

            <Label
                Text="Click the buttons below to check out places to eat or sights to see!"
                TextColor="Black"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

            <Button
                x:Name="FoodBtn"
                Text="Restaurants" 
                SemanticProperties.Hint="Counts the number of times you click"
                BackgroundColor="#034F07"
                Clicked="GoToFoodPage"
                HorizontalOptions="Fill" />

            <Button
                x:Name="TourBtn"
                Text="Tourist Attractions" 
                SemanticProperties.Hint="Counts the number of times you click"
                BackgroundColor="#034F07"
                Clicked="GoToTourPage"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
