<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="STprogram2LH.NewPage2"
             BackgroundColor="{StaticResource PrimaryBackground}"
             Title="NewPage2">
    <ScrollView>
        <HorizontalStackLayout Margin="20" Spacing="6">
            <VerticalStackLayout Spacing="6">
                <Label Text="Stone Mountain:" Style="{StaticResource Headline}" TextColor="Black" FontAttributes="Bold" />
                <Button
                    x:Name="FoodBtn"
                    Text="Restaurants" 
                    Margin="15"
                    SemanticProperties.Hint="Counts the number of times you click"
                    BackgroundColor="#034F07"
                    Clicked="GoToFoodPage"
                    HorizontalOptions="Fill"
                    VerticalOptions="Start"/>
                <Button 
                    x:Name="CloseBtn"
                    Text="Back" 
                    Margin="15"
                    Clicked="OnGoToFirstpage"
                    BackgroundColor="#034F07"
                    HorizontalOptions="Fill"
                    VerticalOptions="Start"/>
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="6">
                <Image
                Source="stone.jpg"
                Aspect="AspectFill"
                HeightRequest="200"
                SemanticProperties.Description="dot net bot in a race car number eight" />
                <Label Text="Atlanta, Georgia"
                       TextColor="Black"
                       Style="{StaticResource SubHeadline}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Button 
                    Text="Double Click To Learn More" 
                    Clicked="OnActionButtonClicked"
                    BackgroundColor="#034F07" />
            </VerticalStackLayout>
            <Label Text="Forsyth Park:" Style="{StaticResource Headline}" TextColor="Black" FontAttributes="Bold" />
            <VerticalStackLayout Spacing="6">
                <Image
                    Source="forsyth.jpg"
                    Aspect="AspectFill"
                    HeightRequest="200"
                    SemanticProperties.Description="dot net bot in a race car number eight" />
                <Label Text="Savannah, Georgia"
                       TextColor="Black"
                       Style="{StaticResource SubHeadline}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Button 
                    Text="Double Click To Learn More" 
                    Clicked="OnActionButtonClicked1"
                    BackgroundColor="#034F07" />
            </VerticalStackLayout>
        </HorizontalStackLayout>
    </ScrollView>
</ContentPage>